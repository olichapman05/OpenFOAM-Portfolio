FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases          (heavy light);

heavy
{
    transportModel  Newtonian;
    nu              1e-06;
    rho             1000;
}

light
{
    transportModel  Newtonian;
    nu              1.48e-05;
    rho             111.111;
}

sigma           0.03;

